# XJTU school code (default keeps current XJTU config)
XJTU_SCHOOL_CODE=13558

# Backward compatibility: if old env is used, it still works
# SCHOOL_CODE=13558

# Server port
# PORT=3000

# Data source mode: json | mongo
# DATA_SOURCE=json

# MongoDB connection (required when DATA_SOURCE=mongo)
# MONGO_URI=mongodb://127.0.0.1:27017
# MONGO_DB_NAME=xjtuhub
# MONGO_CONNECT_TIMEOUT_MS=5000
# MONGO_MAX_POOL_SIZE=10

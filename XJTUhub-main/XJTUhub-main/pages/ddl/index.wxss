page {
  background: var(--bg-page);
}

.container {
  padding: 24rpx;
}

.card-shell {
  border-radius: 16rpx;
  border: 1rpx solid var(--border-color);
  background: var(--bg-card);
  box-shadow: 0 12rpx 26rpx -22rpx var(--shadow-color);
}

.tips {
  padding: 20rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.list {
  margin-top: 20rpx;
}

.item {
  margin-bottom: 18rpx;
  padding: 22rpx;
}

.item.done {
  opacity: 0.72;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  width: calc(100% - 120rpx);
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.item.done .title {
  text-decoration: line-through;
}

.meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.reset-btn {
  margin-top: 14rpx;
  width: 100%;
  height: 88rpx;
  border-radius: 14rpx;
  background: var(--theme);
  color: #ffffff;
}

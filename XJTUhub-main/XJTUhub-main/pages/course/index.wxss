page {
  background: var(--bg-page);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.container {
  padding: 0 20rpx;
}

.refresh-btn {
  width: 58rpx;
  height: 58rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--border-color);
  color: var(--text-primary);
  background: var(--bg-card);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.week-switcher {
  width: 320rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
}

.week-nav-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 999rpx;
  color: var(--text-secondary);
  background: var(--surface-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.week-nav-btn.disabled {
  opacity: 0.38;
}

.week-label {
  min-width: 180rpx;
  height: 50rpx;
  border-radius: 999rpx;
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.week-list {
  position: sticky;
  top: 0;
  left: auto;
  width: 100%;
  height: 102rpx;
  border-radius: 20rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: 0 12rpx 24rpx -20rpx var(--shadow-color);
  display: flex;
  align-items: center;
  background: var(--bg-card);
  z-index: 2;
}

.now-month {
  width: 64rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.week-item {
  width: calc((100% - 64rpx) / 7);
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1),
    background-color 200ms cubic-bezier(0.22, 1, 0.36, 1);
}

.week-item.active {
  background-color: var(--theme);
  border-radius: 16rpx;
  transform: translateY(-1rpx);
}

.week-name {
  font-size: 24rpx;
  color: var(--text-primary);
}

.week-date {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.active .week-name,
.active .week-date {
  color: #fff;
}

.course-content {
  width: 100%;
  margin-top: 14rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 20rpx;
  background: var(--bg-card);
  box-shadow: 0 14rpx 30rpx -22rpx var(--shadow-color);
  display: flex;
  overflow: hidden;
}

.course-nums {
  width: 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(15, 118, 110, 0.06) 0%, rgba(15, 118, 110, 0.01) 100%);
}

.course-num {
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.course-list {
  width: 100%;
  height: 100%;
  position: relative;
}

.course-item {
  position: absolute;
  width: calc((100% - 50rpx) / 7);
  padding: 6rpx;
}

.course-item__content {
  width: 100%;
  height: 100%;
  border-radius: 14rpx;
  border: 1rpx solid var(--border-color);
  color: var(--text-primary);
  text-align: left;
  line-height: 1.35;
  padding: 12rpx 10rpx;
  box-shadow: 0 12rpx 24rpx -22rpx var(--shadow-color);
  overflow: hidden;
}

.course-item__title {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  max-height: 64rpx;
  overflow: hidden;
}

.course-item__meta {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: var(--text-secondary);
  line-height: 1.3;
  max-height: 52rpx;
  overflow: hidden;
}

.switch-week__popup {
  padding: 28rpx;
  background: var(--bg-card);
}

.switch-week__title {
  text-align: center;
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.switch-week__list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 22rpx;
}

.switch-week__item {
  width: 20%;
  padding: 8rpx;
}

.switch-week__item-box {
  width: 100%;
  height: 88rpx;
  background: var(--surface-soft);
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 14rpx;
}

.switch-week__item-box.active {
  background-color: var(--theme);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.course-swpier {
  width: calc(100% - 50rpx);
  height: 1200rpx;
  background: transparent;
}

.course-swpier swiper-item,
.course-list {
  background: transparent;
}

.course-detail-popup {
  background: var(--bg-card);
}

.course-detail__head {
  padding: 28rpx 30rpx 22rpx;
  border-bottom: 1rpx solid var(--border-color);
  background: linear-gradient(180deg, rgba(15, 118, 110, 0.08) 0%, rgba(15, 118, 110, 0.01) 100%);
}

.course-detail__title {
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.course-detail__subtitle {
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.course-detail__body {
  max-height: 56vh;
  overflow-y: auto;
  padding: 10rpx 30rpx;
}

.course-detail__row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(100, 116, 139, 0.16);
}

.course-detail__row:last-child {
  border-bottom: none;
}

.course-detail__key {
  color: var(--text-secondary);
  font-size: 24rpx;
  white-space: nowrap;
}

.course-detail__val {
  flex: 1;
  color: var(--text-primary);
  font-size: 26rpx;
  line-height: 1.45;
  text-align: right;
  word-break: break-all;
}

.course-detail__footer {
  padding: 22rpx 30rpx 28rpx;
  border-top: 1rpx solid var(--border-color);
}

.course-detail__btn {
  height: 78rpx;
  border-radius: 16rpx;
  background: var(--theme);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}
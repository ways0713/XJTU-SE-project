<wxs src="../../utils/tools.wxs" module="tools"></wxs>
<view class="theme-{{themeMode}}">
  <cu-custom bgColor="bg-nav-theme" customBack="{{true}}" bind:back="update">
    <view slot="backText">
      <view bindtap="update" class="refresh-btn ios-tap">
        <text class="cuIcon-refresh"></text>
      </view>
    </view>
    <view slot="content">
      <view class="week-switcher">
        <view bindtap="stepWeek" data-step="-1" class="week-nav-btn ios-tap {{nowWeek <= 1 ? 'disabled' : ''}}">
          <text class="cuIcon-back"></text>
        </view>
        <view bindtap="selectWeek" class="week-label ios-tap">
          <text>第{{nowWeek}}周</text>
          <text class="cuIcon-unfold"></text>
        </view>
        <view bindtap="stepWeek" data-step="1" class="week-nav-btn ios-tap {{nowWeek >= totalWeek ? 'disabled' : ''}}">
          <text class="cuIcon-right"></text>
        </view>
      </view>
    </view>
  </cu-custom>
  <view class="container ios-page {{pageReady ? 'is-ready' : ''}}">
    <view class="week-list">
      <view class="now-month">
        <text>{{nowMonth < 10 ? '0' + nowMonth : nowMonth}}</text>
        <text>月</text>
      </view>
      <view class="week-item ios-tap {{nowMonth == todayMonth && todayDay == weekCalendar[index] ? 'active' : ''}}" wx:for="{{weekDayCount}}" wx:key>
        <text class="week-name">周{{weekIndexText[index]}}</text>
        <text class="week-date">{{weekCalendar[index] == 1 ? ((nowMonth == 12 ? 1 : (nowMonth + 1)) + '月') :(weekCalendar[index] < 9 ? '0' : '' ) + weekCalendar[index] + '日' }}</text>
      </view>
    </view>
    <view class="course-content">
      <view class="course-nums">
        <view class="course-num" wx:for="{{12}}" wx:key>
          {{index + 1 > 9 ? index + 1 : '0' + (index + 1)}}
        </view>
      </view>
      <swiper duration="{{firstEntry ? 0 : 300}}" circular class="course-swpier" current="{{nowWeek-1}}" bindchange="swiperSwitchWeek">
        <swiper-item wx:for="{{totalWeek}}" wx:key="index" wx:for-index="weekIndex">
          <view class="course-list">
            <view wx:if="{{tools.indexOf(item.weeks,weekIndex+1)}}" bindtap="navCourseDetail" data-index="{{index}}" class="course-item ios-tap" wx:for="{{courseList}}" wx:key="key" style="top: {{(item.section - 1) * 120}}rpx;left:{{(item.week - 1) * ((windowWidth * 2 - 50) / 7)}}rpx;height:{{item.sectionCount * 120}}rpx;">
              <view class="course-item__content" style="background-color: {{courseColor[item.name]}};">
                <view class="course-item__title">{{item.name}}</view>
                <view class="course-item__meta">{{item.address ? item.address : '未知教室'}}</view>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>
  </view>
  <van-popup show="{{showSwitchWeek}}" position="bottom" bind:close="hideSwitchWeek" round>
    <view class="switch-week__popup">
      <view class="switch-week__title">切换周数</view>
      <view class="switch-week__list">
        <view class="switch-week__item" wx:for="{{totalWeek}}" wx:key>
          <view bindtap="switchWeek" data-week="{{item+1}}" class="switch-week__item-box ios-tap {{nowWeek == index + 1 ? 'active' : ''}}">{{item + 1}}</view>
        </view>
      </view>
    </view>
  </van-popup>
  <van-popup
    show="{{showCourseDetail}}"
    position="center"
    round
    overlay-style="background: rgba(2, 6, 23, 0.44);"
    custom-style="width: 84%; max-height: 72vh; border-radius: 24rpx; overflow: hidden;"
    bind:close="hideCourseDetail"
  >
    <view class="course-detail-popup theme-{{themeMode}}" wx:if="{{activeCourse}}">
      <view class="course-detail__head">
        <view class="course-detail__title">{{activeCourse.name}}</view>
        <view class="course-detail__subtitle">第{{nowWeek}}周 · {{activeCourse.weekDay}}</view>
      </view>
      <view class="course-detail__body">
        <view class="course-detail__row" wx:for="{{courseDetailRef}}" wx:key="key">
          <text class="course-detail__key">{{item.title}}</text>
          <text class="course-detail__val">{{activeCourse[item.key]}}</text>
        </view>
      </view>
      <view class="course-detail__footer">
        <view class="course-detail__btn ios-tap" bindtap="hideCourseDetail">我知道了</view>
      </view>
    </view>
  </van-popup>
</view>
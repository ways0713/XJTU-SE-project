.container {
	min-height: 100vh;
	background: var(--bg-page);
	padding: 24rpx 24rpx calc(170rpx + env(safe-area-inset-bottom));
}

.card {
	background: var(--bg-card);
	border: 1rpx solid var(--border-color);
	border-radius: 18rpx;
	padding: 24rpx;
	margin-bottom: 18rpx;
	box-shadow: 0 12rpx 32rpx -20rpx var(--shadow-color);
}

.user-card {
	background: linear-gradient(135deg, rgba(8, 145, 178, 0.08) 0%, var(--bg-card) 100%);
}

.user-title {
	font-size: 30rpx;
	font-weight: 600;
	color: var(--text-primary);
}

.user-id {
	margin-top: 10rpx;
	font-size: 28rpx;
	color: var(--text-primary);
}

.user-desc {
	margin-top: 12rpx;
	font-size: 24rpx;
	color: var(--text-secondary);
}

.menu-item {
	height: 88rpx;
	display: flex;
	align-items: center;
	justify-content: space-between;
	font-size: 28rpx;
	color: var(--text-primary);
}

.menu-item:not(:last-child) {
	border-bottom: 1rpx solid var(--border-color);
}

.menu-left {
	display: flex;
	align-items: center;
}

.menu-icon {
	margin-right: 16rpx;
	font-size: 30rpx;
	color: var(--theme);
}

.arrow {
	color: var(--text-secondary);
}

.logout-btn {
	width: 100%;
	height: 88rpx;
	border-radius: 14rpx;
	background: rgba(34, 197, 94, 0.18);
	color: var(--text-primary);
}

.login-btn {
	margin-top: 18rpx;
	height: 82rpx;
	border-radius: 14rpx;
	background: rgba(15, 118, 110, 0.14);
	border: 1rpx solid rgba(15, 118, 110, 0.38);
	color: var(--theme);
	font-weight: 700;
}

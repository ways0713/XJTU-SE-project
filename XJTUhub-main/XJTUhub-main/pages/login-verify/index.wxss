page {
  background: var(--bg-page);
}

.container {
  min-height: 100vh;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-shell {
  width: 100%;
  max-width: 720rpx;
}

.action-row {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 18rpx;
}

.skip-btn {
  height: 62rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
}

.card {
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 32rpx -20rpx var(--shadow-color);
}

.header {
  display: flex;
  align-items: center;
  padding: 28rpx;
}

.brand-mark {
  width: 84rpx;
  height: 84rpx;
  border-radius: 20rpx;
  background: rgba(8, 145, 178, 0.1);
  color: var(--theme);
  font-size: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-info {
  margin-left: 20rpx;
}

.brand-title {
  font-size: 34rpx;
  color: var(--text-primary);
  font-weight: 700;
}

.brand-subtitle {
  margin-top: 6rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.login {
  margin-top: 20rpx;
  padding: 26rpx 22rpx;
}

.field-icon {
  width: 48rpx;
  text-align: center;
  color: var(--text-secondary);
  font-size: 30rpx;
  margin-right: 20rpx;
}

.login .cu-btn {
  width: 100%;
  height: 92rpx;
  border-radius: 18rpx;
  background: var(--theme);
  color: #ffffff;
  margin-top: 30rpx;
  font-weight: 600;
}

.form-item {
  height: 92rpx;
  border-radius: 16rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--border-color);
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.checkbox-item {
  display: flex;
  align-items: center;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.form-item .verify-img {
  width: 160rpx;
  height: 70rpx;
  border-radius: 12rpx;
  border: 1rpx solid var(--border-color);
}

.checkbox-item .margin-left-sm {
  margin-left: 10rpx;
}

.form-item input {
  color: var(--text-primary);
}
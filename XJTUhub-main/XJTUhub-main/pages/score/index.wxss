page {
  background: var(--bg-page);
}

.container {
  padding: 20rpx;
}

.card-shell {
  border-radius: 20rpx;
  border: 1rpx solid var(--border-color);
  background: var(--bg-card);
  box-shadow: 0 12rpx 26rpx -22rpx var(--shadow-color);
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  padding: 10rpx;
}

.header > view {
  border-radius: 16rpx;
  background: var(--surface-soft);
  height: 100rpx;
}

.score-term {
  width: calc(100% - 112rpx);
  padding: 8rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-primary);
}

.score-list {
  width: 100%;
  margin-top: 26rpx;
  padding: 30rpx;
}

.term-name {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: 600;
  text-align: center;
}

.list {
  margin-top: 30rpx;
}

.score-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 84rpx;
  margin-top: 12rpx;
  padding: 10rpx 0;
}

.score-item:not(:last-child) {
  border-bottom: 1rpx solid var(--border-color);
}

.course-name {
  font-size: 30rpx;
  color: var(--text-primary);
}

.score-item__hint {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.course-score {
  font-size: 32rpx;
  color: var(--theme);
  font-weight: 700;
}

.course-score.fail {
  color: #ef4444;
}

.update-btn {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  color: var(--theme);
}

.score-detail {
  background: var(--bg-card);
}

.score-detail__head {
  padding: 28rpx 30rpx 22rpx;
  border-bottom: 1rpx solid var(--border-color);
  background: linear-gradient(180deg, rgba(15, 118, 110, 0.08) 0%, rgba(15, 118, 110, 0.01) 100%);
}

.score-detail__title {
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.score-detail__subtitle {
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.score-detail__badge {
  margin-top: 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: var(--theme);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

.score-detail__body {
  max-height: 56vh;
  overflow-y: auto;
  padding: 10rpx 30rpx;
}

.score-detail__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(100, 116, 139, 0.16);
}

.score-detail__row:last-child {
  border-bottom: none;
}

.score-detail__key {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.score-detail__val {
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 600;
}

.score-detail__footer {
  padding: 22rpx 30rpx 28rpx;
  border-top: 1rpx solid var(--border-color);
}

.score-detail__btn {
  height: 78rpx;
  border-radius: 16rpx;
  background: var(--theme);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-empty {
  margin-top: 26rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  color: var(--text-secondary);
  font-size: 26rpx;
}
